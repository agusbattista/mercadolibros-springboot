    {
      "name": "create book",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    let jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"UUID\", jsonData.uuid);",
              "    pm.collectionVariables.set(\"ISBN\", jsonData.isbn);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
